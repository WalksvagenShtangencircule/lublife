/var/log/mongodb/*.log {
    daily
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    maxsize 100M
    copytruncate
    postrotate
        if systemctl is-active --quiet mongod 2>/dev/null; then
            systemctl kill -s USR1 mongod 2>/dev/null || true
        fi
    endscript
}
