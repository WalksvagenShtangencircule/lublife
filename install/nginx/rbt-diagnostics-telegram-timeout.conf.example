# Фрагмент для вставки в server { } ДО блока `location /frontend` (и для :443, и для :80 при необходимости).
# POST /frontend/diagnostics/telegram и GET /frontend/diagnostics/telegramWait ждут ответа от
# api.telegram.org (часто через Tor SOCKS и повторы) дольше стандартных 60s nginx → иначе 504.
# После правки: sudo nginx -t && sudo systemctl reload nginx

        location ~ ^/(frontend|api)/diagnostics/(telegram|telegramWait)$ {
                root /opt/rbt/server;
                rewrite ^ /frontend.php break;
                include snippets/fastcgi-php.conf;
                fastcgi_pass unix:/var/run/php/php-fpm.sock;
                fastcgi_read_timeout 300s;
                fastcgi_send_timeout 300s;
        }
