{
  "meta": {
    "title": "CityHome — каталог HTTP API и модель сущностей",
    "version": 1,
    "urlShape": "{SMARTACCESS_BASE_URL}/{api}/{method}[/{id}][?query]",
    "virtualEndpoints": [
      {
        "path": "server/ping",
        "note": "Обрабатывается в frontend.php без api/server/ping.php; ответ 204."
      }
    ],
    "mcpTools": {
      "smapi_request": "Универсальный вызов API (метод задаётся телом; по умолчанию только GET, см. SMARTACCESS_MCP_HTTP_METHODS).",
