  "entityNodes": [
    {
      "id": "region",
      "kind": "address",
      "apis": [
        "addresses/region",
        "addresses/addresses",
        "addresses/search"
      ]
    },
    {
      "id": "house",
      "kind": "address+ops",
      "apis": [
        "addresses/house",
        "houses/house",
        "houses/path",
        "houses/leaf",
        "houses/search"
      ]
    },
    {
      "id": "entrance",
      "kind": "housePart",
      "apis": [
        "houses/entrance",
        "houses/sharedEntrances"
      ]
    },
    {
      "id": "flat",
      "kind": "housePart",
      "apis": [
        "houses/flat",
        "houses/flats"
      ]
    },
    {
      "id": "domophone",
      "kind": "device",
      "apis": [
        "houses/domophone",
        "houses/domophones"
      ]
    },
    {
      "id": "camera",
      "kind": "device",
      "apis": [
        "houses/cameras",
        "cameras/camera",
        "cameras/cameras",
        "subscribers/flatCameras",
        "subscribers/subscriberCameras"
      ]
    },
    {
      "id": "subscriber",
      "kind": "person",
      "apis": [
        "subscribers/subscriber",
        "subscribers/subscribers",
        "subscribers/search*"
      ]
    },
    {
      "id": "key",
      "kind": "access",
      "apis": [
        "subscribers/key",
        "subscribers/keys"
      ]
    },
    {
      "id": "device",
      "kind": "subscriberEquip",
      "apis": [
        "subscribers/device",
        "subscribers/devices"
      ]
    },
    {
      "id": "user",
      "kind": "account",
      "apis": [
        "accounts/user",
        "accounts/users",
        "user/*"
      ]
    },
    {
      "id": "group",
      "kind": "acl",
      "apis": [
        "accounts/group",
        "accounts/groups",
        "accounts/groupUsers"
      ]
    },
    {
      "id": "company",
      "kind": "org",
      "apis": [
        "companies/company",
        "companies/companies"
      ]
    },
    {
      "id": "tt_issue",
      "kind": "ticket",
      "apis": [
        "tt/issue",
        "tt/issues",
        "tt/journal",
        "tt/comment",
        "tt/file"
      ]
    },
    {
      "id": "tt_project",
      "kind": "ticket",
      "apis": [
        "tt/project",
        "tt/catalog",
        "tt/status",
        "tt/workflow"
      ]
    },
    {
      "id": "media_stream",
      "kind": "media",
      "apis": [
        "mediaserver/stream",
        "mediaserver/streams",
        "mediaserver/cameraStream"
      ]
    },
    {
      "id": "analytics_event",
      "kind": "telemetry",
      "apis": [
        "analytics/events",
        "analytics/stats",
        "analytics/eventPreview"
      ]
    },
    {
      "id": "queue",
      "kind": "ops",
      "apis": [
        "queues/queues"
      ]
    },
    {
      "id": "file_asset",
      "kind": "blob",
      "apis": [
        "files/file",
        "files/files",
        "ud363/download",
        "ud363/upload"
      ]
    },
    {
      "id": "note",
      "kind": "content",
      "apis": [
        "notes/note",
        "notes/notes",
        "notes/search"
      ]
    },
    {
      "id": "mkb_card",
      "kind": "knowledge",
      "apis": [
        "mkb/card",
        "mkb/cards",
        "mkb/desk"
      ]
    }
  ],
  "intersections": [
    {
      "entities": [
        "house",
        "flat"
      ],
      "relation": "1:N",
      "via": "houses/flats, houses/flat; адресная привязка в addresses/*"
    },
    {
      "entities": [
        "house",
        "entrance"
      ],
      "relation": "1:N",
      "via": "houses/entrance; sharedEntrances для связных подъездов"
    },
    {
      "entities": [
        "flat",
        "subscriber"
      ],
      "relation": "N:N",
      "via": "subscribers/* (привязка абонента к квартире/дому)"
    },
    {
      "entities": [
        "flat",
        "key"
      ],
      "relation": "1:N",
      "via": "subscribers/keys — ключи в разрезе квартиры/дома"
    },
    {
      "entities": [
        "subscriber",
        "device"
      ],
      "relation": "1:N",
      "via": "subscribers/devices"
    },
    {
      "entities": [
        "flat",
        "camera"
      ],
      "relation": "N:N",
      "via": "subscribers/flatCameras; houses/cameras на уровне дома"
    },
    {
      "entities": [
        "house",
        "domophone"
      ],
      "relation": "1:N",
      "via": "houses/domophones, houses/domophone"
    },
    {
      "entities": [
        "house",
        "company"
      ],
      "relation": "N:N",
      "via": "компания как владелец/обслуживающая — companies/* + объекты дома"
    },
    {
      "entities": [
        "user",
        "group"
      ],
      "relation": "N:N",
      "via": "accounts/groupUsers; права — authorization/rights"
    },
    {
      "entities": [
        "tt_issue",
        "tt_project"
      ],
      "relation": "N:1",
      "via": "tt/issue, tt/issues, tt/project"
    },
    {
      "entities": [
        "tt_issue",
        "file_asset"
      ],
      "relation": "N:N",
      "via": "tt/file, files/* — вложения задач"
    },
    {
      "entities": [
        "analytics_event",
        "house"
      ],
      "relation": "N:1",
      "via": "analytics/events, stats — привязка к объекту/контексту доступа"
    },
    {
      "entities": [
        "camera",
        "media_stream"
      ],
      "relation": "1:N",
      "via": "mediaserver/cameraStream, stream"
    },
    {
      "entities": [
        "house",
        "analytics_event"
      ],
      "relation": "observability",
      "via": "analytics/* + diagnostics/*"
    },
    {
      "entities": [
        "subscriber",
        "inbox"
      ],
      "relation": "message",
      "via": "inbox/message"
    },
    {
      "entities": [
        "address_node",
        "geo"
      ],
      "relation": "lookup",
      "via": "geo/suggestions + адресные PUT в addresses/*"
    },
    {
      "entities": [
        "config",
        "provider"
      ],
      "relation": "integration",
      "via": "configs/* + providers/* + mqtt/config"
    },
    {
      "entities": [
        "cdr",
        "subscriber"
      ],
      "relation": "call",
      "via": "cdr/cdr — соотнесение с абонентом/номером в данных биллинга"
    },
    {
      "entities": [
        "mkb_card",
        "tt_issue"
      ],
      "relation": "optional",
      "via": "ссылки из карточек базы знаний в контексте поддержки (зависит от внедрения)"
    },
    {
      "entities": [
        "note",
        "house"
      ],
      "relation": "annotation",
      "via": "notes/* к объектам (если поддерживается клиентом)"
    },
    {
      "entities": [
        "cs_cell",
        "tt_issue"
      ],
      "relation": "spreadsheet",
      "via": "cs/sheet, cs/cell — данные в таблицах по задачам"
    },
    {
      "entities": [
        "relational_db",
        "mcp_tools"
      ],
      "relation": "read_only",
      "via": "mcp_data/schema, mcp_data/pgSelect (лимит строк, транзакция READ ONLY)"
    },
    {
      "entities": [
        "clickhouse",
        "mcp_tools"
      ],
      "relation": "read_only",
      "via": "mcp_data/clickhouseSelect (max_result_rows)"
    },
    {
      "entities": [
        "server_config",
        "mcp_tools"
      ],
      "relation": "snapshot",
      "via": "mcp_data/configSnapshot (секреты вырезаны)"
    }
  ],
