{
    "defaultServer": "https://your-host.example/frontend",
    "defaultLanguage": "ru",
    "languages": {
        "ru": "Русский",
        "en": "English"
    },
    "modules": [
        "assistant",
        "addresses",
        "virtualDomophones",
        "analytics",
        "mediaserver",
        "queues",
        "users",
        "groups",
        "permissions",
        "tt",
        "diagnostics",
        "tools",
        "vendorKeys",
        "asterisk",
        "cs",
        "darkmode",
        "custom",
        "about",
        "companies",
        "providers",
        "geocoder",
        "mqtt",
        "contacts",
        "mkb",
        "notes",
        "notifications",
        "map"
    ],
    "asterisk": {
        "ws": "wss://your-host.example/wss",
        "ice": [
            {
                "urls": [
                    "stun:stun.l.google.com:19302"
                ]
            }
        ],
        "sipDomain": "your-host.example:5060"
    },
    "map": {
        "tile": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
        "crs": "EPSG3857",
        "default": {
            "lat": 51.505,
            "lon": -0.09,
            "zoom": 13
        },
        "min": 4,
        "max": 18
    },
    "regExp": {
        "phone": "^(7 \\(\\d{3}\\) \\d{3}-\\d{2}-\\d{2}|7\\d{10})$",
        "rfid": "^[0-9A-F]{14}$"
    },
    "defaultRoute": "#about",
    "logo": "rbt",
    "phonePattern": "7 (###) ###-##-##",
    "printServer": "https://your-host.example/print",
    "addresses": {
        "houseFlatsTable": {
            "columns": [
                "flat",
                "openCode",
                "contract"
            ]
        }
    },
    "brandGithubUser": "your-github-username",
    "brandHideSidebarTitle": false,
    "brandSidebarTitle": "SmartAccess"
}
